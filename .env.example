# Database — local dev (Docker)
DATABASE_URL=postgresql://linkupgo:linkupgo@localhost:5434/linkupgo

# Neon — remote database (used by db:neon:* scripts)
# Base URL without search_path — scripts append ?options=-csearch_path=dev or prod
# NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/linkupgo?sslmode=require

# Session
SESSION_SECRET=dev-secret

# OpenAI (required for AI planner/orchestrator)
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Google Places (required for venue suggestions)
# GOOGLE_PLACES_API_KEY=...

# Perplexity (optional, for web search)
# PERPLEXITY_API_KEY=...

# Resend (optional, for email notifications)
# RESEND_API_KEY=...

# Production — CORS and cookies (only needed when web + API on different subdomains)
# ALLOWED_ORIGINS=https://linkupgoapp.com
# COOKIE_DOMAIN=.linkupgoapp.com

# Production — JWT secret for mobile auth (auto-generated if unset)
# JWT_SECRET=...

# Google Ads — Web (AdSense)
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_BANNER_SLOT=yyyyyyyyyy
# VITE_ADSENSE_INLINE_SLOT=zzzzzzzzzz
